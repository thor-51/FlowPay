# Copy this file to .env and adjust as needed for local docker-compose runs.
# docker compose automatically reads a .env file in the project root.

# --- Database ---
DB_URL=jdbc:postgresql://postgres:5432/tps_db
DB_USERNAME=tps_user
DB_PASSWORD=tps_password

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# --- JWT ---
# Generate a strong secret for anything beyond local dev, e.g.:
#   openssl rand -base64 64
JWT_SECRET=change-this-development-secret-key-minimum-256-bits-long-please
JWT_ACCESS_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=604800000

# --- New Relic (optional, see docs/NEW_RELIC.md) ---
NEW_RELIC_ENABLED=false
NEW_RELIC_APP_NAME=transaction-processing-system
NEW_RELIC_LICENSE_KEY=

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:3000
